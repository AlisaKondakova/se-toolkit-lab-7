# Bot Configuration
# Copy this file to .env.bot.secret and fill in real values

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# LMS API Configuration
LMS_API_URL=http://localhost:42002
LMS_API_KEY=your_lms_api_key_here

# LLM API Configuration (for Task 3)
LLM_API_URL=http://localhost:42005
LLM_API_KEY=your_llm_api_key_here

# Debug mode (true/false)
DEBUG=false
